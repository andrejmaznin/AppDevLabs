<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="gui.MissionFrame">
  <grid id="27dc6" binding="Main" layout-manager="GridLayoutManager" row-count="2" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="10" vgap="10">
    <margin top="10" left="10" bottom="10" right="10"/>
    <constraints>
      <xy x="20" y="20" width="750" height="550"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="topPanel" layout-manager="GridLayoutManager" row-count="1" column-count="2" same-size-horizontally="true" same-size-vertically="false" hgap="10" vgap="10">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          
          <grid id="leftCol" layout-manager="GridLayoutManager" row-count="6" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties/>
            <border type="none" title="Основная информация"/>
            <children>
              <component id="lblId" class="javax.swing.JLabel"><constraints><grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/></constraints><properties><text value="ID миссии:"/></properties></component>
              <component id="idValue" class="javax.swing.JTextField" binding="idValue"><constraints><grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/></constraints><properties><editable value="false"/></properties></component>
              
              <component id="lblDate" class="javax.swing.JLabel"><constraints><grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/></constraints><properties><text value="Дата:"/></properties></component>
              <component id="dateValue" class="javax.swing.JTextField" binding="dateValue"><constraints><grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/></constraints><properties><editable value="false"/></properties></component>
              
              <component id="lblLoc" class="javax.swing.JLabel"><constraints><grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/></constraints><properties><text value="Локация:"/></properties></component>
              <component id="locationValue" class="javax.swing.JTextField" binding="locationValue"><constraints><grid row="2" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/></constraints><properties><editable value="false"/></properties></component>
              
              <component id="lblRes" class="javax.swing.JLabel"><constraints><grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/></constraints><properties><text value="Результат:"/></properties></component>
              <component id="resultValue" class="javax.swing.JTextField" binding="resultValue"><constraints><grid row="3" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/></constraints><properties><editable value="false"/></properties></component>
              
              <component id="lblDmg" class="javax.swing.JLabel"><constraints><grid row="4" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/></constraints><properties><text value="Ущерб:"/></properties></component>
              <component id="damageValue" class="javax.swing.JTextField" binding="damageValue"><constraints><grid row="4" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/></constraints><properties><editable value="false"/></properties></component>
              
              <component id="lblCom" class="javax.swing.JLabel"><constraints><grid row="5" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/></constraints><properties><text value="Примечание:"/></properties></component>
              <component id="commentValue" class="javax.swing.JTextField" binding="commentValue"><constraints><grid row="5" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/></constraints><properties><editable value="false"/></properties></component>
            </children>
          </grid>

          <grid id="rightCol" layout-manager="GridLayoutManager" row-count="5" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties/>
            <border type="none" title="Дополнительные сведения"/>
            <children>
              <component id="lblCurseN" class="javax.swing.JLabel"><constraints><grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/></constraints><properties><text value="Проклятие:"/></properties></component>
              <component id="curseNameValue" class="javax.swing.JTextField" binding="curseNameValue"><constraints><grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/></constraints><properties><editable value="false"/></properties></component>
              
              <component id="lblCurseL" class="javax.swing.JLabel"><constraints><grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/></constraints><properties><text value="Угроза:"/></properties></component>
              <component id="curseLevelValue" class="javax.swing.JTextField" binding="curseLevelValue"><constraints><grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/></constraints><properties><editable value="false"/></properties></component>
              
              <component id="lblEnv" class="javax.swing.JLabel"><constraints><grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/></constraints><properties><text value="Среда:"/></properties></component>
              <component id="envValue" class="javax.swing.JTextField" binding="envValue"><constraints><grid row="2" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/></constraints><properties><editable value="false"/></properties></component>
              
              <component id="lblCiv" class="javax.swing.JLabel"><constraints><grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/></constraints><properties><text value="Гражданские:"/></properties></component>
              <component id="civValue" class="javax.swing.JTextField" binding="civValue"><constraints><grid row="3" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/></constraints><properties><editable value="false"/></properties></component>
              
              <component id="lblEnemy" class="javax.swing.JLabel"><constraints><grid row="4" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/></constraints><properties><text value="Противник:"/></properties></component>
              <component id="enemyValue" class="javax.swing.JTextField" binding="enemyValue"><constraints><grid row="4" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/></constraints><properties><editable value="false"/></properties></component>
            </children>
          </grid>
        </children>
      </grid>

      <tabbedpane id="tabPane" binding="tabbedPane">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          
          <scrollpane id="sp1">
            <constraints><tabbedpane title="Маги-участники"/></constraints>
            <properties/><border type="none"/>
            <children><component id="listSorc" class="javax.swing.JList" binding="sorcerersList"><constraints/><properties/></component></children>
          </scrollpane>

          <scrollpane id="sp2">
            <constraints><tabbedpane title="Примененные техники"/></constraints>
            <properties/><border type="none"/>
            <children><component id="listTech" class="javax.swing.JList" binding="techniquesList"><constraints/><properties/></component></children>
          </scrollpane>

          <scrollpane id="sp3">
            <constraints><tabbedpane title="Хронология событий"/></constraints>
            <properties/><border type="none"/>
            <children><component id="listTime" class="javax.swing.JList" binding="timelineList"><constraints/><properties/></component></children>
          </scrollpane>
          
        </children>
      </tabbedpane>

    </children>
  </grid>
</form>